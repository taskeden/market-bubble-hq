# ─── Market Bubble HQ — environment configuration ────────────────────────────
# Copy to `.env.local` and fill in to tune the LIVE platform adapters.
# The app ships in LIVE mode (real Twitch/Kick/YouTube/X rooms). Set the master
# switch below to "simulation" to run the built-in lively demo crowd instead.

# Live data master switch ("live" | "simulation"). Defaults to live.
NEXT_PUBLIC_DATA_MODE=live

# The Market Bubble channel handles each adapter should follow.
NEXT_PUBLIC_TWITCH_CHANNEL=fazebanks
NEXT_PUBLIC_KICK_CHANNEL=ansem
NEXT_PUBLIC_X_HANDLE=MarketBubble

# ── YouTube featured stream (/api/youtube): live broadcast, else latest episode.
#    Resolve the channel ID from the @handle once and pin it here.
NEXT_PUBLIC_YOUTUBE_CHANNEL_ID=UC2Yw4-WyejthY7OLpbVX4Ug
NEXT_PUBLIC_YOUTUBE_HANDLE=MarketBubble

# ── Twitch (anonymous IRC read works without these; provide for higher limits)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ── Kick (public channel websocket; no credentials required for read)
KICK_CHATROOM_ID=

# ── X / Twitter API v2 (filtered stream / mentions)
X_BEARER_TOKEN=

# ── Bubbles AI co-host (OpenAI). Powers her CHAT replies via /api/bubbles/chat.
#    Without a key, the Chat panel shows a setup prompt.
OPENAI_API_KEY=
#    Optional model override (defaults to gpt-4o-mini; e.g. gpt-4o for richer replies).
OPENAI_MODEL=

# ── Bubbles voice (ElevenLabs text-to-speech). Server-side key powers
#    /api/bubbles/speak (synthesis) + /api/bubbles/voices (catalog lookup).
ELEVENLABS_API_KEY=
#    The chosen voice id for Bubbles (her pinned ElevenLabs voice).
NEXT_PUBLIC_ELEVENLABS_VOICE_ID=
#    Hands-free VOICE mode — an ElevenLabs Conversational AI agent. Create one in
#    the ElevenLabs dashboard (assign her voice + a Bubbles persona), then paste
#    its agent id here. /api/bubbles/conversation-token mints a session token.
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=
